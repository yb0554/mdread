{
  "name": "mdread",
  "private": true,
  "version": "1.2.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "version-check": "node scripts/check-version.cjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run version-check && npm run build",
    "build:e2e": "cross-env VITE_E2E=true node scripts/build-e2e.cjs",
    "test:e2e": "npm run build:e2e && wdio run wdio.conf.cjs",
    "generate:sbom": "node scripts/generate-sbom.cjs",
    "generate:checksums": "node scripts/generate-checksums.cjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "marked": "^15",
    "marked-highlight": "^2.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitest/coverage-v8": "^3.2.7",
    "@wdio/cli": "^9.27.1",
    "@wdio/jasmine-framework": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "cross-env": "^7.0.3",
    "jsdom": "^26.1.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  }
}
